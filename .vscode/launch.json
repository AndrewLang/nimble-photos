{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Backend (LLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/backend/target/debug/nimble-photos.exe",
            "args": [],
            "cwd": "${workspaceFolder}/backend",
