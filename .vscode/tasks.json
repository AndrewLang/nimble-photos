{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "backend: build debug",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "--package",
                "nimble-photos",
                "--bin",
                "nimble-photos"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ]
        },
        {
            "label": "backend: run",
            "type": "shell",
            "command": "cargo",
            "args": [
                "run",
                "--package",
                "nimble-photos",
                "--bin",
                "nimble-photos"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "problemMatcher": [
                "$rustc"
            ]
        }
    ]
}
